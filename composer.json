{
  "name": "ages/grid",
  "description": "Reusable Nette UI Grid component with Nextras ORM",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "Ages\\Grid\\": "src/"
    }
  },
  "require": {
    "php": ">=8.4",
    "nette/application": "^3.1",
    "nette/forms": "^3.1",
    "latte/latte": "^3.0",
    "nextras/orm": "^5.0",
    "phpoffice/phpspreadsheet": "^2.1"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.0"
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "scripts": {
    "phpstan": "phpstan analyse"
  }
}
